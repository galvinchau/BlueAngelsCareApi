// bac-hms/bac-api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * Individual = hồ sơ bệnh nhân/khách hàng
 * code      = mã hiển thị: IND-2025-000001
 */

// ✅ NEW: Individual status (for Pending/Active/Inactive)
enum IndividualStatus {
  PENDING
  ACTIVE
  INACTIVE
}

// ✅ NEW: Billing payer for Rate Setup
// Hiện tại BAC chỉ dùng ODP
enum BillingPayer {
  ODP
}

// ✅ NEW: Residential placement type for House Management
enum ResidentialPlacementType {
  FULL_TIME_247
  HOME_VISIT_SPLIT
}

// ✅ NEW: Claim status
enum ClaimStatus {
  DRAFT
  SUBMITTED
  PAID
  DENIED
  VOID
}

model Individual {
  id   String @id @default(cuid())
  code String @unique

  firstName  String
  middleName String?
  lastName   String
  dob        String
  gender     String?
  ssnLast4   String?
  medicaidId String? @db.VarChar(32)

  branch   String
  location String

  // ✅ NEW: status for operations (Pending/Active/Inactive)
  status IndividualStatus @default(PENDING)

  primaryPhone   String?
  secondaryPhone String?
  email          String?

  address1 String?
  address2 String?
  city     String?
  county   String?
  state    String?
  zip      String?

  // acceptedServices: form gửi lên là mảng string, DB lưu dạng CSV cho đơn giản
  acceptedServices String

  // Emergency contacts
  emergency1Name           String?
  emergency1Relationship   String?
  emergency1PhonePrimary   String?
  emergency1PhoneSecondary String?
  emergency1Notes          String?

  emergency2Name           String?
  emergency2Relationship   String?
  emergency2PhonePrimary   String?
  emergency2PhoneSecondary String?
  emergency2Notes          String?

  // Billing / guardian
  billingSameAsPrimary Boolean @default(true)
  billingAddress1      String?
  billingAddress2      String?
  billingCity          String?
  billingState         String?
  billingZip           String?

  guardianName  String?
  guardianPhone String?
  repPayeeName  String?
  repPayeePhone String?

  // Clinical
  pcpName    String?
  pcpPhone   String?
  pcpFax     String?
  pcpNpi     String?
  pcpAddress String?
  allergies  String?

  // Preparedness / equipment
  priorityCode       String?
  mobility           String?
  equipOxygen        Boolean @default(false)
  equip_cpap         Boolean @default(false)
  equip_ventilator   Boolean @default(false)
  equip_iv_pump      Boolean @default(false)
  equip_syringe_pump Boolean @default(false)
  equip_feeding_tube Boolean @default(false)
  equip_nebulizer    Boolean @default(false)
  equip_wheelchair   Boolean @default(false)
  equip_hospital_bed Boolean @default(false)
  equipOther         String?

  // Preferences
  prefTime        String?
  prefNotes       String?
  langPrimary     String?
  langSecondary   String?
  caregiverGender String?
  prefOther       String?

  // Advanced directives
  advType      String?
  advDateIn    String?
  advDateOut   String?
  advStatus    String?
  advPhysician String?
  advAttach    String?

  // =====================================================
  //  HOUSE MANAGEMENT V1 (additive only)
  // =====================================================
  houseId                  String?
  residentialPlacementType ResidentialPlacementType?
  homeVisitSchedule        String?
  housingCoverage          String?
  careRateTier             String?
  roomLabel                String?
  behaviorSupportLevel     String?
  appointmentLoad          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payers      Payer[]
  medications Medication[]
  diagnoses   Diagnosis[]

  // Relations mới cho Schedule / Visit / ISP
  masterScheduleTemplates MasterScheduleTemplate[]
  scheduleWeeks           ScheduleWeek[]
  scheduleShifts          ScheduleShift[]
  visits                  Visit[]
  ispAllocations          ISPAllocation[]
  healthIncidentReports   HealthIncidentReport[]

  // ✅ ADD: Authorizations / Claims
  authorizations Authorization[]
  claims         Claim[]
  claimItems     ClaimItem[]

  // ISP & BSP form (lưu toàn bộ dữ liệu form dạng JSON)
  ispBspForm IspBspForm?

  // ✅ NEW: relation to House
  house House? @relation(fields: [houseId], references: [id], onDelete: SetNull)

  @@index([houseId])
  @@index([residentialPlacementType])
}

/**
 * Employee = hồ sơ nhân viên Blue Angels Care
 * employeeId = mã hiển thị: BAC-E-2025-001
 */
model Employee {
  id String @id @default(cuid())

  // Demographics
  firstName  String
  middleName String?
  lastName   String
  dob        String?
  gender     String?
  phone      String?
  email      String

  educationLevel String?
  ssn            String?

  // Employment Info
  employeeId      String  @unique
  role            String?
  status          String?
  hireDate        String?
  terminationDate String?
  employmentType  String?
  branch          String?
  workLocation    String?
  supervisorName  String?

  // Address
  address1 String?
  address2 String?
  city     String?
  state    String?
  zip      String?

  // Emergency Contact
  emergencyName              String?
  emergencyRelationship      String?
  emergencyPhone             String?
  emergencyEmail             String?
  emergencyPreferredLanguage String?
  emergencyAddress           String?

  // Work Preferences
  preferredShift  String?
  canWorkWeekends Boolean @default(false)
  canWorkHolidays Boolean @default(false)
  maxWeeklyHours  Int?
  notes           String?

  // Notification Preferences
  notifyByEmail       Boolean @default(true)
  notifyBySMS         Boolean @default(false)
  notifyByInApp       Boolean @default(true)
  sendScheduleChanges Boolean @default(true)
  sendPayrollUpdates  Boolean @default(true)
  sendPolicyUpdates   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations mới
  templateDefaultShifts MasterTemplateShift[]  @relation("TemplateDefaultDSP")
  plannedShifts         ScheduleShift[]        @relation("PlannedDSP")
  actualShifts          ScheduleShift[]        @relation("ActualDSP")
  visits                Visit[]                @relation("VisitDSP")
  healthIncidentReports HealthIncidentReport[]

  // Supervisors cho Admin Users
  userSupervisors UserSupervisor[]

  isMobileUser Boolean @default(false)

  // ✅ NEW: refresh tokens for mobile "remember device"
  mobileRefreshTokens MobileRefreshToken[]
  mobilePushTokens    MobilePushToken[]

  // =====================================================
  //  HOUSE MANAGEMENT V1 (additive only)
  // =====================================================
  houseLinks          HouseEmployee[]
  houseShiftStaffings HouseShiftStaffing[]
}

/**
 * House Management V1
 * Additive only, no breaking change to old system
 */
model House {
  id String @id @default(cuid())

  code String @unique
  name String

  programType String?
  status      String  @default("ACTIVE")

  address1 String?
  address2 String?
  city     String?
  county   String?
  state    String?
  zip      String?

  phone String?

  capacity Int @default(1)

  primaryOccupancyModel String?

  billingNote        String?
  careComplexityNote String?
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  residents      Individual[]
  staffLinks     HouseEmployee[]
  shiftStaffings HouseShiftStaffing[]

  @@index([status])
  @@index([county])
}

model HouseEmployee {
  id String @id @default(cuid())

  houseId    String
  employeeId String

  roleInHouse String?
  isPrimary   Boolean @default(false)
  isActive    Boolean @default(true)
  notes       String?

  house    House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([houseId, employeeId])
  @@index([houseId, isActive])
  @@index([employeeId, isActive])
}

model HouseShiftStaffing {
  id String @id @default(cuid())

  shiftId    String
  houseId    String
  employeeId String

  roleInShift String?
  isPrimary   Boolean @default(false)
  notes       String?

  shift    ScheduleShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  house    House         @relation(fields: [houseId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shiftId, employeeId])
  @@index([shiftId])
  @@index([houseId])
  @@index([employeeId])
}

/**
 * Payer: các đối tượng thanh toán: Primary / Secondary
 */
model Payer {
  id          String  @id @default(cuid())
  type        String
  name        String
  plan        String?
  memberId    String
  groupId     String?
  startDate   String?
  endDate     String?
  eligibility String?
  notes       String?

  individualId String
  individual   Individual @relation(fields: [individualId], references: [id], onDelete: Cascade)

  ispAllocations ISPAllocation[]
}

/**
 * Medications
 */
model Medication {
  id       String  @id @default(cuid())
  name     String
  dose     String?
  schedule String?

  individualId String
  individual   Individual @relation(fields: [individualId], references: [id], onDelete: Cascade)
}

/**
 * Diagnoses (ICD)
 */
model Diagnosis {
  id          String  @id @default(cuid())
  icd         String
  description String?
  onset       String?

  individualId String
  individual   Individual @relation(fields: [individualId], references: [id], onDelete: Cascade)
}

/**
 * Counter dùng để sinh code
 */
model Counter {
  id    String @id
  value Int
}

/**
 * Service = danh mục dịch vụ
 */
model Service {
  id String @id @default(cuid())

  serviceCode String  @unique
  serviceName String
  billingCode String?
  category    String
  description String?
  status      String
  billable    Boolean @default(true)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  masterTemplateShifts MasterTemplateShift[]
  scheduleShifts       ScheduleShift[]
  visits               Visit[]
  ispAllocations       ISPAllocation[]
  serviceRates         ServiceRate[]

  // ✅ ADD: Authorizations / Claims
  authorizations Authorization[]
  claims         Claim[]
  claimItems     ClaimItem[]
}

/**
 * Authorization
 */
model Authorization {
  id String @id @default(cuid())

  authorizationNumber String

  individualId String
  serviceId    String

  payer     String
  eventCode String?
  format    String
  program   String?

  modifier1 String?
  modifier2 String?
  modifier3 String?
  modifier4 String?

  startDate DateTime
  endDate   DateTime

  maximum   Float @default(0)
  used      Float @default(0)
  remaining Float @default(0)

  snapshotThroughDate DateTime?
  manualUsed          Float     @default(0)
  manualMissed        Float     @default(0)

  status String @default("PENDING")
  source String @default("MANUAL")

  voided   Boolean @default(false)
  comments String?

  intervalType  String?
  intervalLimit Float?
  intervalStart DateTime?
  intervalEnd   DateTime?

  serviceCode String
  serviceName String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  individual Individual @relation(fields: [individualId], references: [id], onDelete: Cascade)
  service    Service    @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  claims     Claim[]
  claimItems ClaimItem[]

  @@unique([individualId, authorizationNumber, serviceId])
  @@index([individualId, startDate])
  @@index([serviceId, startDate])
  @@index([status])
  @@index([authorizationNumber])
}

/**
 * ServiceRate
 */
model ServiceRate {
  id String @id @default(cuid())

  payer BillingPayer @default(ODP)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  rate Float

  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([payer, serviceId, effectiveFrom], name: "service_rate_payer_service_effective_from_unique")
  @@index([payer])
  @@index([serviceId])
  @@index([payer, serviceId])
  @@index([payer, serviceId, effectiveFrom])
  @@index([payer, serviceId, isActive])
  @@map("ServiceRate")
}

// =====================================================
//  ENUMS CHO SCHEDULE / VISIT
// =====================================================

enum ScheduleStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  NOT_COMPLETED
  CANCELLED
  BACKUP_PLAN
}

enum VisitSource {
  MOBILE
  OFFICE_EDIT
  AUTO_MATCH
}

enum CancelledBy {
  INDIVIDUAL
  DSP
  OFFICE
}

enum AwakeEventType {
  CHECK_IN_AWAKE_STARTED
  REMINDER_SENT
  CONFIRMED_AWAKE
  AUTO_CHECKOUT_FAIL_CONFIRM
  MANUAL_CHECKOUT
  SHIFT_COMPLETED
}

// =====================================================
//  MASTER SCHEDULE TEMPLATE
// =====================================================

model MasterScheduleTemplate {
  id            String    @id @default(cuid())
  individualId  String
  name          String?
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  notes         String?

  individual    Individual            @relation(fields: [individualId], references: [id], onDelete: Cascade)
  shifts        MasterTemplateShift[]
  scheduleWeeks ScheduleWeek[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([individualId, isActive])
}

model MasterTemplateShift {
  id         String @id @default(cuid())
  templateId String
  dayOfWeek  Int
  serviceId  String

  startMinutes Int
  endMinutes   Int

  defaultDspId String?
  billable     Boolean @default(true)
  notes        String?

  template   MasterScheduleTemplate @relation(fields: [templateId], references: [id])
  service    Service                @relation(fields: [serviceId], references: [id])
  defaultDsp Employee?              @relation("TemplateDefaultDSP", fields: [defaultDspId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId, dayOfWeek])
}

// =====================================================
//  WEEKLY SCHEDULE
// =====================================================

model ScheduleWeek {
  id                    String   @id @default(cuid())
  individualId          String
  templateId            String?
  weekStart             DateTime
  weekEnd               DateTime
  generatedFromTemplate Boolean  @default(true)
  notes                 String?
  locked                Boolean  @default(false)

  individual Individual              @relation(fields: [individualId], references: [id], onDelete: Cascade)
  template   MasterScheduleTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  shifts     ScheduleShift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([individualId, weekStart])
}

model ScheduleShift {
  id           String @id @default(cuid())
  weekId       String
  individualId String
  serviceId    String

  plannedDspId String?
  actualDspId  String?

  scheduleDate DateTime
  plannedStart DateTime
  plannedEnd   DateTime

  awakeMonitoringRequired Boolean @default(false)

  status ScheduleStatus @default(NOT_STARTED)

  cancelledBy  CancelledBy?
  cancelledAt  DateTime?
  cancelReason String?

  backupNote String?

  billable Boolean @default(true)
  notes    String?

  week       ScheduleWeek @relation(fields: [weekId], references: [id])
  individual Individual   @relation(fields: [individualId], references: [id], onDelete: Cascade)
  service    Service      @relation(fields: [serviceId], references: [id])

  plannedDsp Employee? @relation("PlannedDSP", fields: [plannedDspId], references: [id])
  actualDsp  Employee? @relation("ActualDSP", fields: [actualDspId], references: [id])

  visits                Visit[]
  healthIncidentReports HealthIncidentReport[]
  houseShiftStaffings   HouseShiftStaffing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weekId])
  @@index([scheduleDate])
  @@index([individualId, scheduleDate])
  @@index([plannedDspId, scheduleDate])
  @@index([actualDspId, scheduleDate])
}

// =====================================================
//  VISIT
// =====================================================

model Visit {
  id String @id @default(cuid())

  scheduleShiftId String?
  individualId    String
  dspId           String
  serviceId       String?

  checkInAt  DateTime
  checkOutAt DateTime?

  source VisitSource @default(MOBILE)

  durationMinutes   Int?
  units             Int?
  isBillable        Boolean @default(true)
  nonBillableReason String?

  gpsLatitude  Float?
  gpsLongitude Float?

  reviewedAt DateTime?

  // =====================================================
  //  AWAKE MONITORING
  // =====================================================

  awakeMonitoringEnabled Boolean @default(false)

  awakeIntervalMinutes Int @default(60)
  awakeGraceMinutes    Int @default(10)

  awakeStatus String?

  lastAwakeConfirmedAt  DateTime?
  nextAwakeConfirmDueAt DateTime?
  awakeDeadlineAt       DateTime?

  autoCheckedOutAt   DateTime?
  autoCheckoutReason String?

  isClaimLocked Boolean   @default(false)
  claimedAt     DateTime?

  scheduleShift  ScheduleShift?  @relation(fields: [scheduleShiftId], references: [id])
  individual     Individual      @relation(fields: [individualId], references: [id], onDelete: Cascade)
  dsp            Employee        @relation("VisitDSP", fields: [dspId], references: [id])
  service        Service?        @relation(fields: [serviceId], references: [id])
  claimItem      ClaimItem?
  awakeEventLogs AwakeEventLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduleShiftId])
  @@index([dspId, checkInAt])
  @@index([individualId, checkInAt])
  @@index([isClaimLocked])
}

model AwakeEventLog {
  id String @id @default(cuid())

  visitId String
  visit   Visit  @relation(fields: [visitId], references: [id], onDelete: Cascade)

  scheduleShiftId String?
  individualId    String
  dspId           String
  serviceId       String?

  eventType AwakeEventType
  eventTime DateTime       @default(now())

  note String?
  meta Json?

  createdAt DateTime @default(now())

  @@index([visitId, eventTime])
  @@index([scheduleShiftId, eventTime])
  @@index([individualId, eventTime])
  @@index([dspId, eventTime])
  @@index([eventType, eventTime])
}

// =====================================================
//  CLAIMS
// =====================================================

model Claim {
  id          String      @id @default(cuid())
  claimNumber String      @unique
  status      ClaimStatus @default(DRAFT)

  payer BillingPayer @default(ODP)

  individualId    String
  authorizationId String?
  serviceId       String

  serviceDateFrom DateTime?
  serviceDateTo   DateTime?

  itemCount   Int     @default(0)
  totalUnits  Decimal @default(0) @db.Decimal(10, 2)
  totalAmount Decimal @default(0) @db.Decimal(12, 2)

  submittedAt DateTime?
  paidAt      DateTime?
  deniedAt    DateTime?
  voidedAt    DateTime?

  submitNote   String?
  denialReason String?
  internalNote String?

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  individual    Individual     @relation(fields: [individualId], references: [id], onDelete: Restrict)
  authorization Authorization? @relation(fields: [authorizationId], references: [id], onDelete: SetNull)
  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  items ClaimItem[]

  @@index([status])
  @@index([payer, status])
  @@index([individualId])
  @@index([authorizationId])
  @@index([serviceId])
  @@index([serviceDateFrom, serviceDateTo])
}

model ClaimItem {
  id String @id @default(cuid())

  claimId String
  visitId String @unique

  individualId    String
  authorizationId String?
  serviceId       String

  visitDate DateTime
  units     Decimal  @db.Decimal(10, 2)
  rate      Decimal  @db.Decimal(10, 2)
  amount    Decimal  @db.Decimal(12, 2)

  startTime DateTime?
  endTime   DateTime?

  note String?

  createdAt DateTime @default(now())

  claim         Claim          @relation(fields: [claimId], references: [id], onDelete: Cascade)
  visit         Visit          @relation(fields: [visitId], references: [id], onDelete: Restrict)
  individual    Individual     @relation(fields: [individualId], references: [id], onDelete: Restrict)
  authorization Authorization? @relation(fields: [authorizationId], references: [id], onDelete: SetNull)
  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([claimId])
  @@index([individualId])
  @@index([authorizationId])
  @@index([serviceId])
  @@index([visitDate])
}

// =====================================================
//  DAILY NOTE
// =====================================================

model DailyNote {
  id String @id @default(cuid())

  shiftId      String
  visitId      String?
  individualId String
  staffId      String
  serviceId    String?

  date DateTime

  individualName String
  staffName      String?
  serviceCode    String
  serviceName    String
  scheduleStart  String
  scheduleEnd    String
  visitStart     String?
  visitEnd       String?

  mileage      Float?
  isCanceled   Boolean @default(false)
  cancelReason String?

  payload Json

  staffReportFileId      String?
  individualReportFileId String?

  staffReportDocPath      String?
  staffReportPdfPath      String?
  individualReportDocPath String?
  individualReportPdfPath String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([individualId, date])
  @@index([staffId, date])
}

// =====================================================
//  ISP ALLOCATION
// =====================================================

model ISPAllocation {
  id           String  @id @default(cuid())
  individualId String
  serviceId    String
  payerId      String?

  startDate DateTime
  endDate   DateTime?

  unitsPerWeek         Int?
  unitsPerMonth        Int?
  totalAuthorizedUnits Int?

  notes String?

  individual Individual @relation(fields: [individualId], references: [id], onDelete: Cascade)
  service    Service    @relation(fields: [serviceId], references: [id])
  payer      Payer?     @relation(fields: [payerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([individualId, serviceId, startDate])
}

// =====================================================
//  ISP & BSP FORM
// =====================================================

model IspBspForm {
  id           String @id @default(cuid())
  individualId String @unique
  formData     Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  individual Individual @relation(fields: [individualId], references: [id], onDelete: Cascade)
}

// =====================================================
//  ADMIN USERS / ROLES / PRIVILEGES
// =====================================================

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  firstName String
  lastName  String
  locked    Boolean @default(false)
  userType  String  @default("ADMIN")

  roles       UserRole[]
  privileges  UserPrivilege[]
  supervisors UserSupervisor[]

  passwordHash      String?
  passwordSalt      String?
  passwordUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

model Role {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  users UserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_roles")
}

model Privilege {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  users UserPrivilege[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_privileges")
}

model UserRole {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String

  @@unique([userId, roleId])
  @@map("admin_user_roles")
}

model UserPrivilege {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  privilege   Privilege @relation(fields: [privilegeId], references: [id], onDelete: Cascade)
  privilegeId String

  @@unique([userId, privilegeId])
  @@map("admin_user_privileges")
}

model UserSupervisor {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  supervisor   Employee @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  supervisorId String

  @@unique([userId, supervisorId])
  @@map("admin_user_supervisors")
}

// =====================================================
//  MEDICATION MODULE
// =====================================================

enum MedicationType {
  SCHEDULED
  PRN
}

enum MedicationOrderStatus {
  ACTIVE
  ON_HOLD
  DISCONTINUED
}

enum MedicationAdminStatus {
  SCHEDULED
  GIVEN
  REFUSED
  MISSED
  HELD
  LATE
  ERROR
}

enum MedicationIncidentSeverity {
  LOW
  MODERATE
  HIGH
}

enum MedicationIncidentStatus {
  OPEN
  IN_REVIEW
  CLOSED
}

model MedicationOrder {
  id String @id @default(cuid())

  individualId   String                @map("individualid")
  medicationName String                @map("medicationname")
  form           String?               @map("form")
  doseValue      Float                 @map("dosevalue")
  doseUnit       String                @map("doseunit")
  route          String                @map("route")
  type           MedicationType        @map("type")
  frequencyText  String?               @map("frequencytext")
  timesOfDay     String[]              @default([]) @map("timesofday")
  startDate      DateTime              @map("startdate")
  endDate        DateTime?             @map("enddate")
  status         MedicationOrderStatus @default(ACTIVE) @map("status")

  prescriberName String? @map("prescribername")
  pharmacyName   String? @map("pharmacyname")
  indications    String? @map("indications")
  allergyFlag    Boolean @default(false) @map("allergyflag")

  administrations MedicationAdministration[]
  inventoryItems  MedicationInventory[]

  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")

  @@index([individualId, status])
  @@map("MedicationOrder")
}

model MedicationAdministration {
  id String @id @default(cuid())

  orderId String          @map("orderid")
  order   MedicationOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  individualId      String                @map("individualid")
  scheduledDateTime DateTime              @map("scheduleddatetime")
  actualDateTime    DateTime?             @map("actualdatetime")
  status            MedicationAdminStatus @map("status")
  reason            String?               @map("reason")
  vitalsSummary     String?               @map("vitalssummary")
  staffId           String?               @map("staffid")
  staffName         String?               @map("staffname")

  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")

  @@index([individualId, scheduledDateTime])
  @@index([orderId, scheduledDateTime])
  @@map("MedicationAdministration")
}

model MedicationInventory {
  id String @id @default(cuid())

  orderId String?          @map("orderid")
  order   MedicationOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  individualId    String    @map("individualid")
  medicationName  String    @map("medicationname")
  isControlled    Boolean   @default(false) @map("iscontrolled")
  currentQuantity Float     @map("currentquantity")
  unit            String    @map("unit")
  minThreshold    Float     @default(0) @map("minthreshold")
  daysRemaining   Int?      @map("daysremaining")
  lastCountDate   DateTime? @map("lastcountdate")

  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")

  @@index([individualId])
  @@index([individualId, isControlled])
  @@map("MedicationInventory")
}

model MedicationIncident {
  id String @id @default(cuid())

  individualId   String                     @map("individualid")
  individualName String                     @map("individualname")
  date           DateTime                   @map("date")
  medicationName String?                    @map("medicationname")
  type           String                     @map("type")
  severity       MedicationIncidentSeverity @map("severity")
  status         MedicationIncidentStatus   @default(OPEN) @map("status")
  notes          String?                    @map("notes")

  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")

  @@index([individualId, date])
  @@index([severity])
  @@index([status])
  @@map("MedicationIncident")
}

model MobileLoginOtp {
  id        String    @id @default(cuid())
  email     String
  code      String
  staffId   String
  staffName String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([email, code])
}

model MobileRefreshToken {
  id        String @id @default(cuid())
  staffId   String
  email     String
  tokenHash String

  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  staff Employee @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([staffId])
  @@index([email])
  @@index([expiresAt])
  @@index([revokedAt])
}

model MobilePushToken {
  id String @id @default(cuid())

  staffId String
  staff   Employee @relation(fields: [staffId], references: [id], onDelete: Cascade)

  expoPushToken String

  platform   String?
  deviceId   String?
  deviceName String?
  appVersion String?

  isActive   Boolean  @default(true)
  lastSeenAt DateTime @default(now())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  revokedAt DateTime?

  @@unique([expoPushToken])
  @@index([staffId])
  @@index([staffId, isActive])
  @@index([isActive])
  @@index([lastSeenAt])
}

// =====================================================
//  TIME KEEPING
// =====================================================

enum OfficeAttendanceSource {
  WEB
  MOBILE
}

enum OfficeWeeklyApprovalStatus {
  PENDING
  APPROVED
}

model OfficeAttendanceEvent {
  id String @id @default(cuid())

  staffId    String
  staffEmail String?
  staffName  String?

  checkInAt  DateTime
  checkOutAt DateTime?

  checkInLat      Float?
  checkInLng      Float?
  checkInAccuracy Float?

  checkOutLat      Float?
  checkOutLng      Float?
  checkOutAccuracy Float?

  source OfficeAttendanceSource @default(WEB)

  flags String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([staffId, checkInAt])
  @@index([staffId, checkOutAt])
}

model OfficeWeeklyApproval {
  id String @id @default(cuid())

  staffId   String
  weekStart DateTime
  weekEnd   DateTime

  computedMinutes Int  @default(0)
  adjustedMinutes Int?
  finalMinutes    Int  @default(0)

  dailyAdjustments Json?

  status OfficeWeeklyApprovalStatus @default(PENDING)

  approvedByUserId String?
  approvedByEmail  String?
  approvedAt       DateTime?

  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, weekStart, weekEnd], name: "staffId_weekStart_weekEnd")
  @@index([weekStart, weekEnd])
  @@index([status])
  @@map("OfficeWeeklyApproval")
}

// =====================================================
//  PAYROLL
// =====================================================

model PayrollRate {
  id String @id @default(cuid())

  employeeId String @unique

  rate         Float?
  trainingRate Float?
  mileageRate  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
}

model PayrollRun {
  id String @id @default(cuid())

  periodFrom  String
  periodTo    String
  generatedAt DateTime @default(now())

  totalsTotalHours   Float @default(0)
  totalsTotalOtHours Float @default(0)
  totalsTotalPay     Float @default(0)

  rows PayrollRow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([periodFrom, periodTo])
}

model PayrollRow {
  id String @id @default(cuid())

  runId String
  run   PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  staffId   String
  staffName String
  staffType String

  employeeSSN String?

  rate         Float
  trainingRate Float?
  mileageRate  Float?

  hours      Float
  otHours    Float
  regularPay Float
  otPay      Float
  totalPay   Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([runId])
  @@index([staffId])
  @@index([staffType])
}

// =====================================================
//  HEALTH & INCIDENT
// =====================================================

enum HealthIncidentReportStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  ASSIGNED
  INVESTIGATED
  CLOSED

  @@map("health_incident_report_status")
}

model HealthIncidentReport {
  id String @id @default(cuid())

  caseNumber String? @unique

  shiftId String?
  shift   ScheduleShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  staffId    String
  staff      Employee @relation(fields: [staffId], references: [id], onDelete: Restrict)
  staffName  String?
  staffEmail String?

  individualId   String?
  individual     Individual? @relation(fields: [individualId], references: [id], onDelete: SetNull)
  individualName String?

  date DateTime

  status      HealthIncidentReportStatus @default(SUBMITTED)
  submittedAt DateTime?

  payload Json

  supervisorName         String?
  supervisorDecision     String?
  supervisorActionsTaken String?
  reviewedAt             DateTime?

  ciName  String?
  ciEmail String?
  ciPhone String?

  ciAssignedAt       DateTime?
  ciAssignedByUserId String?
  ciAssignedByName   String?

  investigationFindings String?
  rootCause             String?
  witnessNotes          String?
  correctiveActions     String?
  recommendation        String?

  investigatedAt        DateTime?
  investigatedByStaffId String?
  investigatedByName    String?

  allowDspViewOutcome Boolean @default(false)
  finalDecision       String?
  finalSummary        String?

  closedAt       DateTime?
  closedByUserId String?
  closedByName   String?

  staffReportDocPath String?
  staffReportPdfPath String?

  caseLogs    HealthIncidentCaseLog[]
  attachments HealthIncidentAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([status])
  @@index([staffId, date])
  @@index([individualId, date])
  @@index([shiftId])
  @@index([ciAssignedAt])
  @@index([investigatedAt])
  @@index([closedAt])
  @@map("HealthIncidentReport")
}

model HealthIncidentCaseLog {
  id String @id @default(cuid())

  reportId String
  report   HealthIncidentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  actionType      String
  actorUserId     String?
  actorEmployeeId String?
  actorName       String?
  actorRole       String?
  note            String?
  meta            Json?

  createdAt DateTime @default(now())

  @@index([reportId, createdAt])
  @@index([actionType])
  @@map("HealthIncidentCaseLog")
}

model HealthIncidentAttachment {
  id String @id @default(cuid())

  reportId String
  report   HealthIncidentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  category    String
  fileName    String
  filePath    String
  mimeType    String?
  fileSize    Int?
  description String?

  uploadedByUserId     String?
  uploadedByEmployeeId String?
  uploadedByName       String?
  uploadedByRole       String?

  createdAt DateTime @default(now())

  @@index([reportId, createdAt])
  @@index([category])
  @@map("HealthIncidentAttachment")
}
